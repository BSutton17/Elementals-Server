{
  "name": "kingdoms-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Authoritative Socket.IO server for Kingdoms",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "nodemon dist/index.js",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "sim": "tsx simulation/src/cli.ts"
  },
  "dependencies": {
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  }
}
