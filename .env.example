# Kingdoms server configuration.
# Copy to `.env` (loaded automatically in development) and adjust as needed.
# In production, provide these via the deployment environment instead.

# Runtime environment: development | production | test
NODE_ENV=development

# TCP port the server listens on
PORT=3001

# Network interface to bind (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Allowed client origin(s) for CORS, comma-separated.
# Required in production; defaults to the Vite dev server in development.
CLIENT_ORIGIN=http://localhost:5173

# Minimum log level: debug | info | warn | error
# Defaults to "debug" in development and "info" otherwise.
LOG_LEVEL=debug
